<Window x:Class="PractikaPM11.GeneralDepartmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PractikaPM11"
        mc:Ignorable="d"
        Title="Терминал общего отдела - ХранительПРО" 
        Height="600" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Icon="icon_general_department.ico">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtWelcome" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5">
            <StackPanel>
                <TextBlock Text="Фильтрация заявок" FontWeight="Bold" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="Тип заявки:" Width="100" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbFilterType" Width="150" Margin="0,0,20,0" SelectionChanged="ApplyFilter"/>

                    <TextBlock Text="Подразделение:" Width="100" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbFilterDepartment" Width="150" Margin="0,0,20,0" SelectionChanged="ApplyFilter"
                              DisplayMemberPath="Name" SelectedValuePath="DepartmentId"/>

                    <TextBlock Text="Статус:" Width="80" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbFilterStatus" Width="130" SelectionChanged="ApplyFilter"/>

                    <Button x:Name="btnRefresh" Content="🔄 Обновить" Width="100" Margin="20,0,0,0" Click="BtnRefresh_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgRequests" Grid.Row="2" AutoGenerateColumns="False" 
                  IsReadOnly="True" AlternatingRowBackground="LightGray"
                  Margin="0,10" SelectionChanged="DgRequests_SelectionChanged">

            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding RequestId}" Width="50"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="60"/>
                <DataGridTextColumn Header="Посетитель" Binding="{Binding VisitorFullName}" Width="150"/>
                <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate}" Width="100"/>
                <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate}" Width="100"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding DepartmentName}" Width="120"/>
                <DataGridTextColumn Header="Цель" Binding="{Binding PurposeName}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" Width="120"/>
                <DataGridTextColumn Header="Дата подачи" Binding="{Binding CreatedAt}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button x:Name="btnLogout" Grid.Row="3" Content="Выйти" Width="100" Height="30" 
                HorizontalAlignment="Right" Margin="0,10" Click="BtnLogout_Click"/>
    </Grid>
</Window>