<Window x:Class="PractikaPM11.GeneralDepartmentLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PractikaPM11"
        mc:Ignorable="d"
        Title="Терминал общего отдела - Вход" 
        Height="289" 
        Width="435"
        WindowStartupLocation="CenterScreen"
        Icon="icon_general_department.ico"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Терминал сотрудника общего отдела" 
                   FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Введите код сотрудника:" FontSize="14" Margin="0,10"/>

        <TextBox Grid.Row="2" x:Name="txtEmployeeCode" FontSize="16" Height="35" 
                 Margin="0,5" MaxLength="10"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="btnLogin" Content="Войти" Width="100" Height="35" Margin="10"
                    Background="Orange" Click="BtnLogin_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35" Margin="10"
                    Background="Gray" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
