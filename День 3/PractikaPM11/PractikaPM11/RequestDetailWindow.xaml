<Window x:Class="PractikaPM11.RequestDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PractikaPM11"
        mc:Ignorable="d"
        Title="Детали заявки" 
        Height="672" 
        Width="614"
        WindowStartupLocation="CenterScreen"
        Icon="icon_general_department.ico">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Информация о заявке" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5">
                <StackPanel>
                    <TextBlock Text="👤 Заявитель" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtUserEmail"/>
                    <TextBlock x:Name="txtVisitorName" Margin="0,5,0,0"/>
                    <TextBlock x:Name="txtPassport"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5">
                <StackPanel>
                    <TextBlock Text="📋 Параметры заявки" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtType"/>
                    <TextBlock x:Name="txtDates" Margin="0,5,0,0"/>
                    <TextBlock x:Name="txtDepartment"/>
                    <TextBlock x:Name="txtPurpose"/>
                    <TextBlock x:Name="txtComment" TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border x:Name="borderBlacklist" Grid.Row="3" BorderBrush="Red" BorderThickness="1" CornerRadius="5" 
                    Padding="10" Margin="0,5" Background="LightPink">
                <TextBlock x:Name="txtBlacklistResult" Foreground="Red" FontWeight="Bold" TextWrapping="Wrap"/>
            </Border>

            <Border x:Name="borderManagement" Grid.Row="4" BorderBrush="Green" BorderThickness="1" CornerRadius="5" 
                    Padding="10" Margin="0,5">
                <StackPanel>
                    <TextBlock Text="⚙ Управление заявкой" FontWeight="Bold" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Дата посещения:" Width="120" VerticalAlignment="Center"/>
                        <DatePicker x:Name="dpVisitDate" Width="150"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Время посещения:" Width="120" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtVisitTime" Width="150" Text="09:00"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5" x:Name="panelRejectionReason">
                        <TextBlock Text="Причина отказа:" Width="120" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtRejectionReason" Width="250" Height="60" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <Button x:Name="btnApprove" Content="✅ Одобрить" Width="100" Margin="5" 
                                Background="Green" Foreground="White" Click="BtnApprove_Click"/>
                        <Button x:Name="btnReject" Content="❌ Отклонить" Width="100" Margin="5" 
                                Background="Red" Foreground="White" Click="BtnReject_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button x:Name="btnClose" Grid.Row="5" Content="Закрыть" Width="100" Height="35" 
                    HorizontalAlignment="Center" Margin="0,10,0,30" Click="BtnClose_Click"/>
        </Grid>
    </ScrollViewer>
</Window>
