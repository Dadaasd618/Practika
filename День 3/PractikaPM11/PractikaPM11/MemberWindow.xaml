<Window x:Class="PractikaPM11.MemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PractikaPM11"
        mc:Ignorable="d"
        Title="Добавление участника группы" 
        Height="600" 
        Width="480"
        WindowStartupLocation="CenterOwner"
        MinHeight="550" 
        MinWidth="450"
        ResizeMode="CanResize"
        Icon="icon.ico">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Новый участник группы" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <!-- Фамилия -->
            <TextBlock Grid.Row="1" Text="Фамилия:*" FontWeight="Bold" Margin="0,5,0,0"/>
            <TextBox Grid.Row="2" x:Name="txtLastName" Margin="0,3,0,10" Height="30"/>

            <!-- Имя -->
            <TextBlock Grid.Row="3" Text="Имя:*" FontWeight="Bold" Margin="0,5,0,0"/>
            <TextBox Grid.Row="4" x:Name="txtFirstName" Margin="0,3,0,10" Height="30"/>

            <!-- Отчество -->
            <TextBlock Grid.Row="5" Text="Отчество:" Margin="0,5,0,0"/>
            <TextBox Grid.Row="6" x:Name="txtMiddleName" Margin="0,3,0,10" Height="30"/>

            <!-- Телефон -->
            <TextBlock Grid.Row="7" Text="Телефон:" Margin="0,5,0,0"/>
            <TextBox Grid.Row="8" x:Name="txtPhone" Margin="0,3,0,10" Height="30" Text="+7 "/>

            <!-- Email -->
            <TextBlock Grid.Row="9" Text="Email:*" FontWeight="Bold" Margin="0,5,0,0"/>
            <TextBox Grid.Row="10" x:Name="txtEmail" Margin="0,3,0,10" Height="30"/>

            <!-- Дата рождения -->
            <TextBlock Grid.Row="11" Text="Дата рождения:*" FontWeight="Bold" Margin="0,5,0,0"/>
            <DatePicker Grid.Row="12" x:Name="dpBirthDate" Margin="0,3,0,10" Height="30"/>

            <!-- Серия паспорта -->
            <TextBlock Grid.Row="13" Text="Серия паспорта:*" FontWeight="Bold" Margin="0,5,0,0"/>
            <TextBox Grid.Row="14" x:Name="txtPassportSeries" MaxLength="4" Margin="0,3,0,10" Height="30"/>

            <!-- Номер паспорта -->
            <TextBlock Grid.Row="15" Text="Номер паспорта:*" FontWeight="Bold" Margin="0,5,0,0"/>
            <TextBox Grid.Row="16" x:Name="txtPassportNumber" MaxLength="6" Margin="0,3,0,10" Height="30"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="17" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="btnSave" Content="✅ Сохранить" Width="120" Height="35" Margin="10" 
                        Background="Green" Foreground="White" Click="BtnSave_Click"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Width="120" Height="35" Margin="10" 
                        Background="Gray" Foreground="White" Click="BtnCancel_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
