<Window x:Class="SecurityTerminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SecurityTerminal"
        mc:Ignorable="d"
        Title="Терминал охраны - ХранительПРО" 
        Height="534" 
        Width="884"
        WindowStartupLocation="CenterScreen"
        >

    <Grid Margin="10,10,10,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtWelcome" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <!-- Панель фильтрации и поиска -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5">
            <StackPanel>
                <TextBlock Text="Фильтрация и поиск" FontWeight="Bold" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="Тип:" Width="50" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbFilterType" Width="100" Margin="0,0,20,0" SelectionChanged="ApplyFilter">
                        <ComboBoxItem Content="Все" IsSelected="True"/>
                        <ComboBoxItem Content="Личная"/>
                        <ComboBoxItem Content="Групповая"/>
                    </ComboBox>

                    <TextBlock Text="Подразделение:" Width="90" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbFilterDepartment" Width="150" Margin="0,0,20,0" 
                              DisplayMemberPath="Name" SelectedValuePath="DepartmentId" SelectionChanged="ApplyFilter"/>

                    <TextBlock Text="Дата:" Width="50" VerticalAlignment="Center"/>
                    <DatePicker x:Name="dpFilterDate" Width="120" SelectedDateChanged="ApplyFilter"/>

                    <Button x:Name="btnClearFilter" Content="✖ Очистить" Width="100" Margin="20,0,0,0" Click="BtnClearFilter_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Поиск (ФИО/паспорт):" Width="150" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtSearch" Width="250" TextChanged="TxtSearch_TextChanged"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Таблица заявок -->
        <DataGrid x:Name="dgRequests" Grid.Row="2" AutoGenerateColumns="False" 
                  IsReadOnly="True" AlternatingRowBackground="LightGray"
                  Margin="0,10" SelectionChanged="DgRequests_SelectionChanged">

            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding RequestId}" Width="50"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="60"/>
                <DataGridTextColumn Header="Посетитель" Binding="{Binding VisitorFullName}" Width="180"/>
                <DataGridTextColumn Header="Паспорт" Binding="{Binding VisitorPassport}" Width="120"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding VisitorPhone}" Width="120"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding DepartmentName}" Width="130"/>
                <DataGridTextColumn Header="Дата посещения" Binding="{Binding StartDate}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопка выхода -->
        <Button x:Name="btnLogout" Content="Выйти" Width="100" Height="30" 
                HorizontalAlignment="Left" Margin="757,4,0,5" Click="BtnLogout_Click"/>
    </Grid>
</Window>
