<Window x:Class="PractikaPM11.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PractikaPM11"
        mc:Ignorable="d"
        Title="ХранительПРО - Вход" Height="488" Width="425"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="ХранительПРО" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Табы для входа и регистрации -->
        <TabControl Grid.Row="1">
            <!-- Вкладка ВХОД -->
            <TabItem Header="Вход">
                <StackPanel Margin="10">
                    <TextBlock Text="Email:" Margin="0,5"/>
                    <TextBox x:Name="txtLoginEmail" Margin="0,5"/>

                    <TextBlock Text="Пароль:" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="txtLoginPassword" Margin="0,5"/>

                    <TextBlock Text="Способ авторизации:" Margin="0,10,0,5"/>
                    <ComboBox x:Name="cmbLoginMethod" Margin="0,5">
                        <ComboBoxItem Content="SQL запрос" IsSelected="True"/>
                        <ComboBoxItem Content="Хранимая процедура"/>
                        <ComboBoxItem Content="ORM"/>
                    </ComboBox>

                    <Button x:Name="btnLogin" Content="Войти" 
                            Background="Green" Foreground="White"
                            Margin="0,20" Padding="10" 
                            Click="BtnLogin_Click"/>
                </StackPanel>
            </TabItem>

            <!-- Вкладка РЕГИСТРАЦИЯ -->
            <TabItem Header="Регистрация">
                <StackPanel Margin="10">
                    <TextBlock Text="Email:" Margin="0,5"/>
                    <TextBox x:Name="txtRegEmail" Margin="0,5"/>

                    <TextBlock Text="Пароль:" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="txtRegPassword" Margin="0,5"/>

                    <TextBlock Text="Подтверждение пароля:" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="txtRegConfirmPassword" Margin="0,5"/>

                    <TextBlock Text="Способ регистрации:" Margin="0,10,0,5"/>
                    <ComboBox x:Name="cmbRegMethod" Margin="0,5">
                        <ComboBoxItem Content="SQL запрос" IsSelected="True"/>
                        <ComboBoxItem Content="Хранимая процедура"/>
                        <ComboBoxItem Content="ORM"/>
                    </ComboBox>

                    <Button x:Name="btnRegister" Content="Зарегистрироваться" 
                            Background="Blue" Foreground="White"
                            Margin="0,20" Padding="10" 
                            Click="BtnRegister_Click"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
