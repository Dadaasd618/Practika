<Window x:Class="DepartmentTerminal.RequestDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DepartmentTerminal"
        mc:Ignorable="d"
        Title="Детали заявки" 
        Height="600" 
        Width="580"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,-16,0">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Информация о заявке" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- Информация о посетителе -->
            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5">
                <StackPanel>
                    <TextBlock Text="👤 Посетитель" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtVisitorName" FontSize="14" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="txtPassport" Margin="0,5,0,0"/>
                    <TextBlock x:Name="txtPhone"/>
                </StackPanel>
            </Border>

            <!-- Информация о заявке -->
            <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5">
                <StackPanel>
                    <TextBlock Text="📋 Параметры заявки" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtType"/>
                    <TextBlock x:Name="txtDates" Margin="0,5,0,0"/>
                    <TextBlock x:Name="txtPurpose"/>
                    <TextBlock x:Name="txtDepartment"/>
                </StackPanel>
            </Border>

            <!-- Время входа/выхода -->
            <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5">
                <StackPanel>
                    <TextBlock Text="⏱ Время посещения" FontWeight="Bold" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Вход:" Width="80" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtEntryTime" Width="120" Text="HH:MM"/>
                        <Button x:Name="btnRecordEntry" Content="✅ Зафиксировать вход" 
                                Width="160" Margin="20,0,0,0" Click="BtnRecordEntry_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Выход:" Width="80" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtExitTime" Width="120" Text="HH:MM"/>
                        <Button x:Name="btnRecordExit" Content="🏁 Зафиксировать выход" 
                                Width="160" Margin="20,0,0,0" Click="BtnRecordExit_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="txtStatus" Foreground="Green" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Чёрный список -->
            <Border Grid.Row="4" BorderBrush="DarkRed" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5">
                <StackPanel>
                    <TextBlock Text="⚠ Чёрный список" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtBlacklistInfo" TextWrapping="Wrap"/>
                    <Button x:Name="btnAddToBlacklist" Content="🚫 Добавить в чёрный список" 
                            Width="200" Margin="0,10" Click="BtnAddToBlacklist_Click"/>
                </StackPanel>
            </Border>

            <Button x:Name="btnClose" Grid.Row="5" Content="Закрыть" Width="100" Height="35" 
                    HorizontalAlignment="Center" Margin="0,20" Click="BtnClose_Click"/>
        </Grid>
    </ScrollViewer>
</Window>
