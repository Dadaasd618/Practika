<Window x:Class="SecurityTerminal.PassWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SecurityTerminal"
        mc:Ignorable="d"
        Title="Пропуск" 
        Height="581" 
        Width="654"
        WindowStartupLocation="CenterScreen"
        >

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Информация о посетителе" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5">
            <StackPanel>
                <TextBlock x:Name="txtVisitorName" FontSize="16" FontWeight="Bold"/>
                <TextBlock x:Name="txtPassport" Margin="0,5,0,0"/>
                <TextBlock x:Name="txtPhone"/>
                <TextBlock x:Name="txtDepartment" Margin="0,5,0,0"/>
                <TextBlock x:Name="txtPurpose"/>
                <TextBlock x:Name="txtDate"/>
                <TextBlock x:Name="txtStatus" Margin="0,5,0,0" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Кнопка для пропуска -->
        <Button x:Name="btnGrantAccess" Grid.Row="2" Content="🚪 РАЗРЕШИТЬ ДОСТУП" 
                Height="50" FontSize="16" FontWeight="Bold"
                Background="Green" Foreground="White"
                Margin="0,20" Click="BtnGrantAccess_Click"/>

        <!-- Кнопка для выхода -->
        <Button x:Name="btnRecordExit" Grid.Row="3" Content="🏁 ЗАФИКСИРОВАТЬ ВЫХОД" 
                Height="50" FontSize="16" FontWeight="Bold"
                Background="Orange" Foreground="White"
                Margin="0,5" Click="BtnRecordExit_Click"/>

        <TextBlock x:Name="txtMessage" Grid.Row="4" Foreground="Green" FontSize="14" 
                   HorizontalAlignment="Center" Margin="0,10"/>

        <Button x:Name="btnClose" Grid.Row="5" Content="Закрыть" Width="100" Height="35" 
                HorizontalAlignment="Center" Margin="0,20" Click="BtnClose_Click"/>
    </Grid>
</Window>